pipeline {
    
    agent {label 'worker-node'}

    environment {

        IMAGE = 'neeraj91\${JOB_NAME}:v1.${BUILD_NUMBER}'
    } 

    stages {

        stage ('checkout') {
            steps {
                checkout scm
            }
        }

        stage ('Unit test') {

            steps {

                sh 'mvn test'
            }
        }

        stage ('Integration Test') {

            steps {

                sh 'mvn verify'
            }
        }

        stage ('Build') {

            steps {

                sh 'mvn clean install'
            }
        }

        stage ('Docker Image Build and tag') {

            steps {

                sh ' docker build -t $IMAGE . '
            }
        }

        stage ('Docker Push') {

            steps {

                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', passwordVariable: 'DOCKERPASS', usernameVariable: 'DOCKERNAME')]) {
                 
                sh 'echo $DOCKERPASS | docker login -u $DOCKERNAME --password-stdin'
                sh 'docker push $IMAGE'

                }
            }
        }
    }
}